# Neon Postgres connection string
# Get it from `npx neonctl@latest connection-string` or the Neon console
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# JWT session secret — generate with: openssl rand -base64 32
JWT_SECRET=your-random-secret-here

# Gmail SMTP for transactional email (welcome + OTP codes)
# Use an App Password — not your Gmail password
# Google Account → Security → 2-Step Verification → App passwords
GMAIL_USER=hello@curiousgeekspm.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Public site URL (used in email links)
NEXT_PUBLIC_SITE_URL=https://curiousgeekspm.com

# Google OAuth — create at console.cloud.google.com
# APIs & Services → Credentials → Create OAuth 2.0 Client ID (Web application)
# Authorized redirect URIs: http://localhost:3000/api/auth/google/callback
#                            https://curiousgeekspm.com/api/auth/google/callback
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
